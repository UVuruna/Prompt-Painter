# Generated images and run state
out/

# The owner's private material shown to agents (never committed)
UV/

# The dedicated Chrome automation profile (logged-in sessions)
chrome-profile/

# Downloaded external binaries (Real-ESRGAN) — never committed
tools/

# Tool before/after backups (restore engine) — transient, never committed
.painter_tmp/

# The owner's local GUI settings
settings.json

# Build outputs (PyInstaller + NSIS pipeline — setup/build.py)
build/
dist/
*.spec
setup/version_info.txt

# Generated app icon (rebuilt from assets/logo.svg on every build)
assets/icon.ico

# Code signing certificate (never commit — back up externally)
setup/cert/

# Python
__pycache__/
*.pyc
.pytest_cache/
